# Docker Hub 用户名
DOCKER_HUB_USER=xuaustin

# Hub 访问端口
WEB_PORT=9999
BIND_IP=0.0.0.0

# 时区
TZ=Asia/Shanghai

# Hub 壳层内容（index.md / blog / projects）——NAS 唯一真源
HUB_CONTENT=/volume1/docker/second-brain/content

# 各 KB 在 NAS 上的内容路径
# wealth KB
WEALTH_RAW=/volume1/docker/wealth/content/raw_material
WEALTH_WIKI=/volume1/docker/wealth/content/wiki
WEALTH_OUTPUT=/volume1/docker/wealth/content/output

# job KB
JOB_WIKI=/volume1/docker/job/content/wiki

# stock KB
STOCK_WIKI=/volume1/docker/stock/content/wiki

# llm KB（待建）
# LLM_WIKI=/volume1/docker/llm/content/wiki

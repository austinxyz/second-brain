# Docker Hub 用户名
DOCKER_HUB_USER=xuaustin

# Hub 访问端口
WEB_PORT=9999
BIND_IP=0.0.0.0

# 时区
TZ=Asia/Shanghai

# Hub 壳层内容（index.md / blog / projects）——NAS 唯一真源
HUB_CONTENT=/volume1/docker/second-brain/content

# 各 KB 在 NAS 上的内容路径
# wealth KB
WEALTH_RAW=/volume1/docker/wealth/content/raw_material
WEALTH_WIKI=/volume1/docker/wealth/content/wiki
WEALTH_OUTPUT=/volume1/docker/wealth/content/output

# job KB（ai-infra-manager，各目录独立挂载）
JOB_SKILLS=/volume1/docker/job/skills
JOB_EXPERIENCE=/volume1/docker/job/experience
JOB_RAW_MATERIAL=/volume1/docker/job/raw_material
JOB_DAILY=/volume1/docker/job/daily
JOB_JOBS=/volume1/docker/job/jobs
JOB_META=/volume1/docker/job/_meta
JOB_POSITIONS=/volume1/docker/job/positions

# stock KB
STOCK_WIKI=/volume1/docker/stock/content/wiki

# journal KB (private)
JOURNAL_CONTENT=/volume1/docker/journal/content

# ai KB
AI_RAW=/volume1/docker/ai/raw
AI_WIKI=/volume1/docker/ai/wiki

# leadership KB
LEADERSHIP_RAW=/volume1/docker/leadership/raw_material
LEADERSHIP_WIKI=/volume1/docker/leadership/wiki
LEADERSHIP_OUTPUT=/volume1/docker/leadership/output
